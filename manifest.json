{
  "manifest_version": 3,
  "name": "SitasiInstan",
  "version": "1.2",
  "description": "Format Otomatis APA 7th & Chicago 17th.",
  "permissions": ["activeTab", "storage", "scripting"],
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}