{
  "manifest_version": 3,
  "name": "SitasiInstan Pro",
  "version": "1.1",
  "description": "Format Otomatis APA 7 & Chicago 17 dengan Smart Casing.",
  "permissions": ["activeTab", "storage"],
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}